---
import '../styles/global.css';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import ThemeToggle from '../components/ThemeToggle.astro';
import { ClientRouter } from 'astro:transitions';

interface Props {
	title: string;
	description?: string;
	image?: string;
}

const { title, description = "JayYuの博客站", image = "/cover.webp" } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const currentPath = Astro.url.pathname;

const navItems = [
    { name: t('nav.home'), path: lang === 'zh' ? '/' : `/${lang}/` },
    { name: t('nav.projects'), path: lang === 'zh' ? '/projects' : `/${lang}/projects` },
    { name: t('nav.blog'), path: lang === 'zh' ? '/blog' : `/${lang}/blog` },
    { name: t('nav.bookmarks'), path: lang === 'zh' ? '/bookmarks' : `/${lang}/bookmarks` },
    { name: t('nav.life'), path: lang === 'zh' ? '/life' : `/${lang}/life` }
];

const isActive = (path: string) => {
    if (path === '/' || path === `/${lang}/`) return currentPath === path;
    return currentPath.startsWith(path);
};

// Language toggle logic: simple switch between / and /en/
const toggleUrl = lang === 'zh' 
  ? '/en' + (currentPath === '/' ? '/' : currentPath) 
  : currentPath.replace(/^\/en/, '') || '/';

// SEO: build canonical URL and full image URL
const siteUrl = Astro.site ? Astro.site.origin : '';
const canonicalUrl = siteUrl ? new URL(currentPath, siteUrl).href : currentPath;
const ogImage = image.startsWith('http') ? image : (siteUrl ? new URL(image, siteUrl).href : image);
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content={description} />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="apple-touch-icon" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>

		<!-- Open Graph -->
		<meta property="og:type" content="website" />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={ogImage} />
		<meta property="og:url" content={canonicalUrl} />
		<meta property="og:site_name" content="Jay Yu's Blog" />
		<meta property="og:locale" content={lang === 'zh' ? 'zh_CN' : 'en_US'} />

		<!-- Twitter Card -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImage} />

		<!-- Canonical -->
		<link rel="canonical" href={canonicalUrl} />

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Noto+Serif+SC:wght@400;600;700&display=swap" rel="stylesheet" />
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.9/dist/katex.min.css" crossorigin="anonymous">

		<!-- Prevent flash of wrong theme -->
		<script is:inline>
			const t = localStorage.getItem('theme') || 'dark';
			document.documentElement.setAttribute('data-theme', t);
		</script>
		<ClientRouter />
	</head>
	<body>
        <!-- Ambient mesh gradient glow -->
        <div class="ambient-glow"></div>

        <div class="container">
            <header>
                <nav>
                    <a href={lang === 'zh' ? '/' : `/${lang}/`} class="logo">jayyu</a>
                    <ul>
                        {navItems.map(item => (
                            <li>
                                <a href={item.path} class={isActive(item.path) ? 'active' : ''}>
                                    {item.name}
                                </a>
                            </li>
                        ))}
                    </ul>
                    <div class="nav-actions">
                        <ThemeToggle lang={lang} />
                        <div class="lang-switch">
                            <a href={toggleUrl}>[{lang === 'zh' ? 'EN' : '中文'}]</a>
                        </div>
                        <div class="contact-wrapper">
                            <span class="contact-trigger">{lang === 'zh' ? '联系我' : 'Contact'}</span>
                            <div class="contact-dropdown">
                                <!-- Break email to avoid Cloudflare obfuscation -->
                                <p>📧 <a href="#" onclick="window.location.href='mailto:'+'jayyu07'+'@'+'163.com'; return false;">jayyu07<span>@</span>163.com</a></p>
                            <p>🐙 <a href="https://github.com/JayYu686" target="_blank">GitHub</a></p>
                        </div>
                    </div>
                </nav>
            </header>
            
            <main>
		        <slot />
            </main>

            <footer>
                <p>&copy; {new Date().getFullYear()} Jay Yu. {t('footer.rights')}</p>
            </footer>
        </div>

        <!-- Cursor glow orb -->
        <div class="cursor-glow" id="cursorGlow"></div>

		<script type="module">
			import mermaid from 'https://cdn.jsdelivr.net/npm/mermaid@10/dist/mermaid.esm.min.mjs';
			
			// Initialize with light/dark theme depending on html data-theme
			const t = document.documentElement.getAttribute('data-theme') === 'light' ? 'default' : 'dark';
			mermaid.initialize({ startOnLoad: false, theme: t });

			document.addEventListener('astro:page-load', async () => {
				const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"], .language-mermaid');
				for (const block of mermaidBlocks) {
					if (block.dataset.rendered) continue;
					
					// Get raw text content, stripping out any spans added by Shiki highlighter
					const rawCode = block.textContent;
					const container = document.createElement('div');
					container.className = 'mermaid';
					container.textContent = rawCode;
					container.style.display = 'flex';
					container.style.justifyContent = 'center';
					container.style.margin = '2rem 0';
					
					// If it's a <pre>, replace it directly. If it's <code>, replace the parent <pre>.
					if (block.tagName === 'PRE') {
						block.replaceWith(container);
					} else {
						const pre = block.closest('pre');
						if (pre) pre.replaceWith(container);
					}
				}
				
				try {
					await mermaid.run({
						querySelector: '.mermaid',
					});
				} catch (e) {
					console.error('Mermaid render error:', e);
				}
			});
		</script>
	</body>
</html>

<script>
    // Cursor-following glow effect dynamically linked to survive ViewTransitions
    document.addEventListener('mousemove', (e) => {
        const glow = document.getElementById('cursorGlow');
        if (glow) {
            glow.style.left = e.clientX + 'px';
            glow.style.top = e.clientY + 'px';
            glow.style.opacity = '1';
        }
    });

    document.addEventListener('mouseleave', () => {
        const glow = document.getElementById('cursorGlow');
        if (glow) {
            glow.style.opacity = '0';
        }
    });

    // Mobile tap toggle for contact dropdown
    document.addEventListener('astro:page-load', () => {
        const contactWrapper = document.querySelector('.contact-wrapper');
        if (contactWrapper) {
            // Need a named function to prevent multiple bindings if page-load fires twice, 
            // but we can just clear it or let Astro handle script re-evaluation.
            // Using a simple delegated approach is safer
            contactWrapper.addEventListener('click', (e) => {
                e.stopPropagation();
                contactWrapper.classList.toggle('show');
            });
        }
    });
    
    document.addEventListener('click', () => {
        const contactWrapper = document.querySelector('.contact-wrapper');
        if (contactWrapper) contactWrapper.classList.remove('show');
    });
</script>

<style>
    /* Cursor-following glow orb */
    .cursor-glow {
        position: fixed;
        width: 350px;
        height: 350px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(88, 166, 255, 0.06) 0%, transparent 70%);
        pointer-events: none;
        transform: translate(-50%, -50%);
        z-index: 0;
        opacity: 0;
        transition: opacity 0.4s ease;
    }

    /* Fixed ambient background glow */
    .ambient-glow {
        position: fixed;
        top: -15vw;
        left: 50%;
        transform: translateX(-50%);
        width: 80vw;
        height: 40vw;
        background: radial-gradient(ellipse at center, var(--accent-glow) 0%, transparent 70%);
        filter: blur(80px);
        opacity: 0.5;
        z-index: 0;
        pointer-events: none;
    }

    /* Page content fade-in */
    @keyframes fadeSlideIn {
        from {
            opacity: 0;
            transform: translateY(6px);
        }
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
    main {
        animation: fadeSlideIn 0.3s ease-out;
        position: relative;
        z-index: 1;
    }

    /* Contact dropdown */
    .contact-wrapper {
        position: relative;
        display: inline-block;
    }

    .contact-trigger {
        color: var(--secondary-text);
        font-size: 0.85rem;
        font-weight: bold;
        padding: 4px 12px;
        border-radius: 6px;
        cursor: pointer;
        transition: color 0.2s ease, background-color 0.2s ease;
        user-select: none;
    }

    .contact-trigger:hover {
        color: #fff;
        background-color: rgba(88, 166, 255, 0.08);
    }

    .contact-dropdown {
        display: none;
        position: absolute;
        right: 0;
        top: calc(100% + 8px);
        background-color: #161b22;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 14px 18px;
        min-width: 220px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4), 0 0 12px rgba(88, 166, 255, 0.08);
        z-index: 100;
    }

    /* Invisible hover bridge to prevent dropdown dismissing when mouse traverses the 8px gap */
    .contact-dropdown::before {
        content: '';
        position: absolute;
        top: -8px;
        left: 0;
        right: 0;
        height: 8px;
    }

    .contact-dropdown p {
        margin: 0 0 8px 0;
        font-size: 0.85rem;
        color: var(--text-color);
        white-space: nowrap;
    }

    .contact-dropdown p:last-child {
        margin-bottom: 0;
    }

    .contact-dropdown a {
        color: var(--accent-color);
        text-decoration: none;
    }

    .contact-dropdown a:hover {
        text-decoration: underline;
    }

    /* Desktop hover */
    .contact-wrapper:hover .contact-dropdown {
        display: block;
    }

    /* Mobile tap */
    .contact-wrapper.show .contact-dropdown {
        display: block;
    }
</style>
