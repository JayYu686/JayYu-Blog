---
import BaseLayout from './BaseLayout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = CollectionEntry<'blog'>['data'];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<BaseLayout title={title} description={description}>
    <article class="post-container">
        <header class="post-header">
            <h1 class="post-title">{title}</h1>
            <div class="post-meta">
                <span><span class="meta-icon">📅</span> <time datetime={pubDate.toISOString()}>{pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}</time></span>
                {updatedDate && (
                    <span class="updated-date">
                        (Updated: <time datetime={updatedDate.toISOString()}>{updatedDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' })}</time>)
                    </span>
                )}
            </div>
        </header>

        <div class="post-content">
            <slot />
        </div>

        <div class="post-footer">
            <a href="/blog" class="back-link">cd ../</a>
        </div>
    </article>
</BaseLayout>

<style>
    .post-container {
        margin-top: 40px;
    }

    .post-header {
        margin-bottom: 40px;
        padding-bottom: 20px;
        border-bottom: 1px dashed var(--border-color);
    }

    .post-title {
        font-size: 2.5rem;
        margin-bottom: 15px;
        color: var(--accent-color);
    }
    
    .post-title::before {
        content: "# ";
        color: var(--text-color);
    }

    .post-meta {
        font-size: 0.95rem;
        color: #8b949e;
        display: flex;
        gap: 15px;
    }

    .post-content {
        line-height: 1.8;
        font-size: 1.05rem;
    }

    .post-content :global(h2), .post-content :global(h3), .post-content :global(h4) {
        margin-top: 2em;
        margin-bottom: 1em;
        color: var(--accent-color);
    }
    
    .post-content :global(h2)::before {
        content: "## ";
        color: var(--text-color);
    }

    .post-content :global(a) {
        color: var(--link-color);
        border-bottom: 1px dashed var(--link-color);
        text-decoration: none;
        transition: all 0.2s ease;
    }
    
    .post-content :global(a:hover) {
        background-color: rgba(88, 166, 255, 0.1);
        border-bottom-style: solid;
    }

    .post-content :global(img) {
        max-width: 100%;
        border-radius: 6px;
        border: 1px solid var(--border-color);
        margin: 20px 0;
    }

    .post-content :global(hr) {
        border: none;
        border-top: 1px dashed var(--border-color);
        margin: 40px 0;
    }

    .post-content :global(blockquote) {
        border-left: 4px solid var(--accent-color);
        margin: 20px 0;
        padding: 10px 20px;
        background-color: var(--code-bg);
        color: var(--text-color);
        border-radius: 0 4px 4px 0;
    }
    
    .post-content :global(pre) {
        margin: 20px 0;
    }

    .post-content :global(ul) {
        padding-left: 20px;
    }
    
    .post-content :global(li) {
        margin-bottom: 10px;
    }

    .post-footer {
        margin-top: 60px;
        padding-top: 20px;
        border-top: 1px dashed var(--border-color);
    }

    .back-link {
        font-size: 1.1rem;
        font-weight: bold;
        color: var(--accent-color);
        text-decoration: none;
    }
    
    .back-link:hover {
        text-decoration: underline;
    }
</style>
