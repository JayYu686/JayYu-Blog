---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="SYNTAX NOIR // 关于我">
	<TopNav activePath="/about/" />
	<Sidebar />
	
	<!-- Main Content Canvas -->
	<main class="lg:ml-64 pt-24 pb-12 px-6 md:px-12 max-w-7xl">
		<!-- Section 1: Root Profile -->
		<section class="mb-20 grid grid-cols-1 md:grid-cols-12 gap-8 items-start">
			<div class="md:col-span-8">
				<div class="flex items-center space-x-2 mb-4 text-on-surface-variant font-mono text-sm">
					<span class="text-primary-container">➜</span>
					<span class="text-tertiary">~</span>
					<span class="text-primary-container">whoami</span>
				</div>
				<h1 class="text-5xl md:text-7xl font-headline font-bold tracking-tighter mb-8 leading-none">
					SYNTAX <span class="text-primary-container">NOIR</span>
				</h1>
				<div class="prose prose-invert max-w-2xl text-on-surface-variant font-body leading-relaxed text-lg">
					专注于手术般的精准执行和极简主义美学，构建高性能数字架构。资深系统架构师与创意开发者。我擅长将复杂的逻辑转化为流畅的编辑体验。
				</div>
			</div>
			<div class="md:col-span-4 flex justify-end">
				<div class="relative group">
					<div class="absolute -inset-2 bg-primary-container opacity-10 blur-xl group-hover:opacity-20 transition-opacity"></div>
					<div class="relative w-48 h-64 bg-surface-container-low overflow-hidden border border-outline-variant/20">
						<img alt="个人照片" class="w-full h-full object-cover grayscale contrast-125 opacity-80" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBBGj9HoKXNhNr5tV1-qWed7UYf13Ep45l_Xirkgk_ZxqXuaNknUOULObLVC1F7EGirVov3rt1LP4A9ATynmchCCiP3h17DTFkt2e4TqrglSDAXA8_VpMsEm0WivmQWQNTLWi857yLAPjjbTRrQacqnEcPgIIo0clOAPqjgvxfKLtyPPEwQSR25cno3HLtVDt223Xa10KraBFX-mqZvCVQiMLiDdFdv8E6tU6_rlgo7YJ2dGbRVOGFoq_oNYlBdBVi4KVlddS5DcUQ0"/>
						<div class="absolute bottom-0 left-0 w-full p-3 bg-surface/80 backdrop-blur-sm border-t border-outline-variant/20">
							<span class="font-label text-[10px] tracking-[0.2em] uppercase text-primary-container">始于 1994 // 运行稳定</span>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!-- Section 2: Skill Matrix -->
		<section class="mb-20">
			<div class="flex items-center mb-12">
				<div class="w-1 h-8 bg-primary-container mr-4"></div>
				<h2 class="text-2xl font-headline font-bold tracking-tight uppercase">技术_技能_矩阵</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-3 gap-1">
				<!-- Frontend -->
				<div class="bg-surface-container-low p-8 border border-outline-variant/10">
					<div class="text-[10px] font-label tracking-[0.3em] text-on-surface-variant uppercase mb-6">/ 前端_核心</div>
					<div class="space-y-6">
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">React / Next.js</span>
								<span class="font-mono text-[10px] text-primary-container">98%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[98%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">TailwindCSS</span>
								<span class="font-mono text-[10px] text-primary-container">95%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[95%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">TypeScript</span>
								<span class="font-mono text-[10px] text-primary-container">92%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[92%]"></div>
							</div>
						</div>
					</div>
				</div>
				<!-- Backend -->
				<div class="bg-surface-container p-8 border border-outline-variant/10">
					<div class="text-[10px] font-label tracking-[0.3em] text-on-surface-variant uppercase mb-6">/ 后端_服务</div>
					<div class="space-y-6">
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">Node.js / Go</span>
								<span class="font-mono text-[10px] text-primary-container">88%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[88%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">PostgreSQL</span>
								<span class="font-mono text-[10px] text-primary-container">90%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[90%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">GraphQL</span>
								<span class="font-mono text-[10px] text-primary-container">85%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[85%]"></div>
							</div>
						</div>
					</div>
				</div>
				<!-- Infrastructure -->
				<div class="bg-surface-container-high p-8 border border-outline-variant/10">
					<div class="text-[10px] font-label tracking-[0.3em] text-on-surface-variant uppercase mb-6">/ 基础_协议</div>
					<div class="space-y-6">
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">Docker / K8s</span>
								<span class="font-mono text-[10px] text-primary-container">82%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[82%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">AWS / GCP</span>
								<span class="font-mono text-[10px] text-primary-container">85%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[85%]"></div>
							</div>
						</div>
						<div class="group">
							<div class="flex justify-between items-end mb-2">
								<span class="font-label text-sm uppercase">CI/CD 流水线</span>
								<span class="font-mono text-[10px] text-primary-container">94%</span>
							</div>
							<div class="h-[2px] w-full bg-outline-variant/20">
								<div class="h-full bg-primary-container w-[94%]"></div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</section>
		<!-- Section 3: Experience Log -->
		<section class="mb-20">
			<div class="flex items-center mb-12">
				<div class="w-1 h-8 bg-primary-container mr-4"></div>
				<h2 class="text-2xl font-headline font-bold tracking-tight uppercase">履历_日志</h2>
			</div>
			<div class="space-y-12 relative before:absolute before:left-[11px] before:top-0 before:h-full before:w-[1px] before:bg-outline-variant/30">
				<!-- Job 1 -->
				<div class="relative pl-12 group">
					<div class="absolute left-0 top-1 w-6 h-6 bg-surface border border-primary-container flex items-center justify-center">
						<div class="w-2 h-2 bg-primary-container"></div>
					</div>
					<div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2">
						<h3 class="text-xl font-headline font-bold text-on-surface">首席架构师 @ SPECTER_SYSTEMS</h3>
						<span class="font-mono text-xs text-primary-container">2021-05-12 — 至今</span>
					</div>
					<p class="text-on-surface-variant font-body mb-4 max-w-3xl">负责将遗留的单体系统迁移到高扩展性的微服务架构。通过边缘计算策略将系统延迟降低了 45%。</p>
					<ul class="space-y-2 text-sm font-label text-on-surface-variant/80">
						<li class="flex items-center"><span class="w-1 h-1 bg-primary-container mr-3"></span>部署了全球规模的分布式数据库。</li>
						<li class="flex items-center"><span class="w-1 h-1 bg-primary-container mr-3"></span>指导由 15 名以上资深工程师组成的团队。</li>
					</ul>
				</div>
				<!-- Job 2 -->
				<div class="relative pl-12 group">
					<div class="absolute left-0 top-1 w-6 h-6 bg-surface border border-outline-variant/30 flex items-center justify-center group-hover:border-primary-container transition-colors">
						<div class="w-2 h-2 bg-outline-variant/30 group-hover:bg-primary-container"></div>
					</div>
					<div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2">
						<h3 class="text-xl font-headline font-bold text-on-surface">全栈工程师 @ NEON_GRID_AGENCY</h3>
						<span class="font-mono text-xs text-on-surface-variant">2018-02-14 — 2021-04-30</span>
					</div>
					<p class="text-on-surface-variant font-body mb-4 max-w-3xl">为财富 500 强客户打造高端数字体验。专注于性能驱动的 React 应用程序和交互式叙事。</p>
					<ul class="space-y-2 text-sm font-label text-on-surface-variant/80">
						<li class="flex items-center"><span class="w-1 h-1 bg-outline-variant mr-3"></span>架构了一个日处理额超过 200 万美元的电商平台。</li>
						<li class="flex items-center"><span class="w-1 h-1 bg-outline-variant mr-3"></span>使用 Tailwind CSS 实现了自定义设计系统。</li>
					</ul>
				</div>
				<!-- Job 3 -->
				<div class="relative pl-12 group">
					<div class="absolute left-0 top-1 w-6 h-6 bg-surface border border-outline-variant/30 flex items-center justify-center group-hover:border-primary-container transition-colors">
						<div class="w-2 h-2 bg-outline-variant/30 group-hover:bg-primary-container"></div>
					</div>
					<div class="flex flex-col md:flex-row md:items-baseline md:justify-between mb-2">
						<h3 class="text-xl font-headline font-bold text-on-surface">初级开发 @ NULL_POINTER_LABS</h3>
						<span class="font-mono text-xs text-on-surface-variant">2016-06-01 — 2018-01-20</span>
					</div>
					<p class="text-on-surface-variant font-body mb-4 max-w-3xl">入门阶段专注于自动化脚本和内部工具开发。掌握了 Unix 哲学的核心基础。</p>
				</div>
			</div>
		</section>
		<!-- Section 4: Current_Activity & Contact (Asymmetric Layout) -->
		<section class="grid grid-cols-1 md:grid-cols-12 gap-8 mb-20">
			<!-- Current_Activity -->
			<div class="md:col-span-7 bg-surface-container-low p-8 border border-outline-variant/10 relative overflow-hidden">
				<div class="absolute top-0 right-0 p-4 opacity-5">
					<span class="material-symbols-outlined text-[120px]">update</span>
				</div>
				<div class="text-[10px] font-label tracking-[0.3em] text-primary-container uppercase mb-6 flex items-center">
					<span class="flex h-2 w-2 rounded-full bg-primary-container mr-2 animate-pulse"></span>
					当前_动态
				</div>
				<div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
					<div>
						<span class="text-[10px] font-mono text-on-surface-variant block mb-3 uppercase opacity-60">正在构建_</span>
						<div class="font-headline font-bold text-lg mb-2">PHANTOM_CORE V3</div>
						<p class="text-sm text-on-surface-variant font-body">一个为极致性能和无服务器部署优化的开源无头 CMS。</p>
					</div>
					<div>
						<span class="text-[10px] font-mono text-on-surface-variant block mb-3 uppercase opacity-60">正在阅读_</span>
						<div class="font-headline font-bold text-lg mb-2">《哥德尔、艾舍尔、巴赫》</div>
						<p class="text-sm text-on-surface-variant font-body">一条永恒的金带。探索数学、逻辑和自指的交集。</p>
					</div>
				</div>
			</div>
			<!-- Contact_Protocol -->
			<div class="md:col-span-5 bg-surface-container-high p-8 border border-outline-variant/10">
				<div class="text-[10px] font-label tracking-[0.3em] text-on-surface-variant uppercase mb-6">/ 联系_协议</div>
				<div class="space-y-4">
					<a class="flex items-center justify-between p-3 border border-outline-variant/10 hover:bg-[#1e1f23] hover:text-[#00FF00] transition-all group" href="#">
						<span class="font-mono text-sm uppercase">GITHUB</span>
						<span class="material-symbols-outlined text-sm">open_in_new</span>
					</a>
					<a class="flex items-center justify-between p-3 border border-outline-variant/10 hover:bg-[#1e1f23] hover:text-[#00FF00] transition-all group" href="#">
						<span class="font-mono text-sm uppercase">LINKEDIN</span>
						<span class="material-symbols-outlined text-sm">open_in_new</span>
					</a>
					<a class="flex items-center justify-between p-3 border border-outline-variant/10 hover:bg-[#1e1f23] hover:text-[#00FF00] transition-all group" href="#">
						<span class="font-mono text-sm uppercase">电子邮件</span>
						<span class="material-symbols-outlined text-sm">alternate_email</span>
					</a>
				</div>
				<div class="mt-8 pt-8 border-t border-outline-variant/10">
					<div class="text-[10px] font-label text-on-surface-variant mb-2">加密_ID</div>
					<div class="font-mono text-[10px] break-all opacity-40">0x7F2A 992B C1D4 8832 FE01 5592</div>
				</div>
			</div>
		</section>
	</main>
	
	<Footer />
</Layout>
