---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="文章 | Jay Yu">
    <h1 class="page-title">blog</h1>
    <p>我的思考、随笔、教程与开发日志。</p>

    <div class="posts-list">
        {posts.map(post => (
            <article class="post-item">
                <a href={`/blog/${post.id}`} class="post-link">
                    <div class="post-info">
                        <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                            {post.data.pubDate.toLocaleDateString('zh-CN', {
                                year: 'numeric',
                                month: '2-digit',
                                day: '2-digit',
                            }).replace(/\//g, '-')}
                        </time>
                        <h2>{post.data.title}</h2>
                        <p class="post-desc">{post.data.description}</p>
                    </div>
                    <div class="post-thumbnail">
                        <img src={post.data.heroImage || "/cover.png"} onerror="this.onerror=null;this.src='/cover.png';" alt="" />
                    </div>
                </a>
            </article>
        ))}
        {posts.length === 0 && (
            <p>未找到任何文章。 echo "Hello World" > first-post.md</p>
        )}
    </div>
</BaseLayout>

<style>
    .posts-list {
        margin-top: 40px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .post-item {
        background-color: transparent;
        border-left: 2px solid transparent;
        padding: 20px;
        transition: all 0.2s ease;
    }
    
    .post-item:hover {
        border-left-color: var(--accent-color);
        background-color: var(--code-bg);
        box-shadow: 0 0 15px rgba(88, 166, 255, 0.08), 0 0 30px rgba(88, 166, 255, 0.04);
    }

    .post-link {
        display: flex;
        flex-direction: column;
        gap: 20px;
        text-decoration: none;
        color: inherit;
    }

    @media (min-width: 600px) {
        .post-link {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .post-info {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 8px;
    }

    .post-date {
        color: #8b949e;
        font-size: 0.9rem;
        font-family: var(--font-mono);
    }

    .post-info h2 {
        margin: 0;
        font-size: 1.3rem;
        color: var(--text-color);
        transition: color 0.2s ease;
    }

    .post-item:hover .post-info h2 {
        color: var(--accent-color);
    }

    .post-info h2::before {
        content: ""; /* Removed arrow for this layout */
    }
    
    .post-desc {
        margin: 0;
        color: #8b949e;
        font-size: 0.95rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .post-thumbnail {
        width: 100%;
        max-width: 240px;
        flex-shrink: 0;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        display: none;
    }

    @media (min-width: 600px) {
        .post-thumbnail {
            display: block;
        }
    }

    .post-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .post-item:hover .post-thumbnail img {
        transform: scale(1.05);
    }
</style>
