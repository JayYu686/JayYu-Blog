---
import BaseLayout from '../../layouts/BaseLayout.astro';

const bookmarks = [
    { category: "Developer Tools", items: [
        { name: "Regex101", url: "https://regex101.com/", desc: "Online regex tester and debugger." },
        { name: "CyberChef", url: "https://gchq.github.io/CyberChef/", desc: "The Cyber Swiss Army Knife - a web app for encryption, encoding, and data operations." },
        { name: "AST Explorer", url: "https://astexplorer.net/", desc: "Web tool to explore ASTs generated by various parsers." },
        { name: "JSON Crack", url: "https://jsoncrack.com/", desc: "Seamlessly visualize your JSON data instantly into graphs." },
        { name: "Vercel", url: "https://vercel.com/", desc: "The platform for frontend developers, providing the speed and reliability innovators need." }
    ]},
    { category: "Design & Inspiration", items: [
        { name: "Awwwards", url: "https://www.awwwards.com/", desc: "Design inspiration and awards." },
        { name: "Fontshare", url: "https://www.fontshare.com/", desc: "Free fonts service from Indian Type Foundry." },
        { name: "Dribbble", url: "https://dribbble.com/", desc: "Discover the world's top designers & creatives." },
        { name: "Figma", url: "https://www.figma.com/", desc: "The collaborative interface design and prototyping tool." }
    ]},
    { category: "Reading & Learning", items: [
        { name: "MDN Web Docs", url: "https://developer.mozilla.org/", desc: "The go-to resource for web development." },
        { name: "Hacker News", url: "https://news.ycombinator.com/", desc: "Tech news and high-quality discussions." },
        { name: "arXiv", url: "https://arxiv.org/", desc: "Open access to e-prints in Physics, Mathematics, Computer Science, and AI." },
        { name: "GitHub Trending", url: "https://github.com/trending", desc: "See what the global GitHub open-source community is most excited about today." }
    ]}
];
---

<BaseLayout title="Bookmarks | Jay Yu">
    <h1 class="page-title">bookmarks</h1>
    <p>A curated list of useful websites, tools, and resources. For more, check out my resource navigation site: <a href="https://jayyu686.top/">JayYu's Resource Nav</a></p>

    <div class="bookmarks-container">
        {bookmarks.map(section => (
            <section class="bookmark-section">
                <h2>{section.category}</h2>
                <ul class="bookmark-list">
                    {section.items.map(item => (
                        <li>
                            <a href={item.url} target="_blank" rel="noopener noreferrer" class="bookmark-link">{item.name}</a>
                            <p class="bookmark-desc">{item.desc}</p>
                        </li>
                    ))}
                </ul>
            </section>
        ))}
    </div>
</BaseLayout>

<style>
    .bookmarks-container {
        margin-top: 40px;
    }

    .bookmark-section {
        margin-bottom: 40px;
    }

    .bookmark-section h2 {
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        margin-bottom: 20px;
        font-size: 1.3rem;
    }
    
    .bookmark-section h2::before {
        content: "## ";
        color: var(--accent-color);
    }

    .bookmark-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .bookmark-list li {
        margin-bottom: 20px;
        padding-left: 15px;
        border-left: 2px solid var(--border-color);
    }
    
    .bookmark-list li:hover {
        border-left-color: var(--accent-color);
        box-shadow: 0 0 12px rgba(88, 166, 255, 0.08);
    }

    .bookmark-link {
        font-size: 1.1rem;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 5px;
    }

    .bookmark-desc {
        margin: 0;
        color: #8b949e;
        font-size: 0.95rem;
    }
</style>
