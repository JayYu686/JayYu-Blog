---
import BaseLayout from '../../layouts/BaseLayout.astro';
import TerminalCard from '../../components/TerminalCard.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import BlogPostItem from '../../components/BlogPostItem.astro';
import { getLangFromUrl } from '../../i18n/utils';
import { getHomeContent, getHomeSectionSuffix } from '../../data/home';
import { getProjects } from '../../data/projects';
import { getCollection } from 'astro:content';

const lang = getLangFromUrl(Astro.url);
const content = getHomeContent(lang);
const suffix = getHomeSectionSuffix(lang);
const blogBasePath = lang === 'zh' ? '/blog' : `/${lang}/blog`;

// Dynamic latest content
const latestProject = (await getProjects('en'))[0];
const latestPost = (await getCollection('blog'))
    .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())[0];

const sectionLabels = lang === 'zh'
    ? { projectsMore: '查看全部项目 →', articlesMore: '查看全部文章 →' }
    : { projectsMore: 'View all projects →', articlesMore: 'View all articles →' };
---

<BaseLayout title={content.title}>
	<div class="hero">
		<h1>Hello, World!</h1>
		<p class="subtitle">{content.subtitle}</p>
        <TerminalCard lines={content.terminal} />
	</div>

    <section class="home-section">
        <h2>{content.sections[0].heading}</h2>
        <div class="latest-project">
            <ProjectCard project={latestProject} />
        </div>
        <a href={content.sections[0].linkHref} class="more-link">{sectionLabels.projectsMore}</a>
    </section>

    <section class="home-section">
        <h2>{content.sections[1].heading}</h2>
        {latestPost && (
            <BlogPostItem post={latestPost} lang={lang} blogBasePath={blogBasePath} />
        )}
        <a href={content.sections[1].linkHref} class="more-link">{sectionLabels.articlesMore}</a>
    </section>
</BaseLayout>

<style>
    .hero {
        margin-top: 40px;
        margin-bottom: 60px;
    }
    
    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }
    
    .hero h1:hover {
        color: var(--accent-color);
        text-shadow: 0 0 16px var(--accent-glow), 0 0 32px rgba(88, 166, 255, 0.15);
    }
    
    .hero h1::before {
        content: "> ";
        color: var(--accent-color);
    }
    
    .subtitle {
        font-size: 1.1rem;
        color: var(--secondary-text);
        margin-bottom: 30px;
    }

    .home-section {
        margin-bottom: 40px;
    }
    
    .home-section h2 {
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }
    
    .home-section h2:hover {
        color: var(--accent-color);
        text-shadow: 0 0 12px var(--accent-glow);
    }
    
    .home-section h2::before {
        content: "## ";
        color: var(--accent-color);
    }

    .latest-project {
        max-width: 400px;
        margin-top: 15px;
    }

    .more-link {
        display: inline-block;
        margin-top: 15px;
        font-size: 0.9rem;
        color: var(--secondary-text);
        text-decoration: none;
        transition: color 0.2s ease;
    }

    .more-link:hover {
        color: var(--accent-color);
        text-decoration: none;
    }
</style>
