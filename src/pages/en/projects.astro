---
import BaseLayout from '../../layouts/BaseLayout.astro';

const projects = [
    { name: "JayYu-Blog", desc: "My personal pure static blog rebuilt with a programmer aesthetic.", lang: "Astro", stars: 4, url: "https://github.com/JayYu686/JayYu-Blog" },
    { name: "cli-util", desc: "Command line utilities to boost developer productivity.", lang: "Rust", stars: 12, url: "#" },
    { name: "dotfiles", desc: "Personal macOS/Linux configuration files.", lang: "Shell", stars: 8, url: "#" },
    { name: "algo-ds", desc: "Data structures and algorithms problems.", lang: "TypeScript", stars: 15, url: "#" }
];
---

<BaseLayout title="Projects | Jay Yu">
    <h1 class="page-title">projects</h1>
    <p>A collection of my open-source projects on GitHub.</p>

    <div class="projects-grid">
        {projects.map(project => (
            <a href={project.url} target="_blank" class="project-card">
                <div class="card-header">
                    <h3>{project.name}</h3>
                </div>
                <p class="desc">{project.desc}</p>
                <div class="card-footer">
                    <span class="lang"><span class="lang-dot"></span> {project.lang}</span>
                    <span class="stars">⭐ {project.stars}</span>
                </div>
            </a>
        ))}
    </div>
</BaseLayout>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .project-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 20px;
        background-color: var(--code-bg);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        transition: all 0.2s ease;
        text-decoration: none;
        color: var(--text-color);
    }

    .project-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-2px);
        text-decoration: none;
    }

    .card-header h3 {
        margin: 0 0 10px 0;
        color: var(--accent-color);
        font-size: 1.2rem;
    }

    .desc {
        font-size: 0.95rem;
        margin: 0 0 20px 0;
        flex-grow: 1;
        color: #8b949e;
    }

    .card-footer {
        display: flex;
        justify-content: flex-start;
        gap: 15px;
        font-size: 0.85rem;
        color: #8b949e;
    }

    .lang-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #f1e05a; 
        margin-right: 4px;
        vertical-align: middle;
    }
</style>
