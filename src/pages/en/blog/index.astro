---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Blog | Jay Yu">
    <h1 class="page-title">blog</h1>
    <p>Thoughts, tutorials, and development logs.</p>

    <div class="posts-list">
        {posts.map(post => (
            <article class="post-item">
                <div class="post-left-col">
                    <div class="post-date">
                        <time datetime={post.data.pubDate.toISOString()}>
                            {post.data.pubDate.toLocaleDateString('en-us', {
                                year: 'numeric',
                                month: 'short',
                                day: 'numeric',
                            })}
                        </time>
                    </div>
                    <div class="post-thumbnail">
                        <img src={post.data.heroImage || "/cover.png"} onerror="this.onerror=null;this.src='/cover.png';" alt="" />
                    </div>
                </div>
                <div class="post-info">
                    <h2><a href={`/blog/${post.id}`}>{post.data.title}</a></h2>
                    <p class="post-desc">{post.data.description}</p>
                </div>
            </article>
        ))}
        {posts.length === 0 && (
            <p>No posts found. echo "Hello World" > first-post.md</p>
        )}
    </div>
</BaseLayout>

<style>
    .posts-list {
        margin-top: 40px;
        display: flex;
        flex-direction: column;
        gap: 30px;
    }

    .post-item {
        display: flex;
        flex-direction: column;
        gap: 15px;
        padding: 20px;
        background-color: transparent;
        border-left: 2px solid transparent;
        transition: all 0.2s ease;
    }
    
    .post-item:hover {
        border-left-color: var(--accent-color);
        background-color: var(--code-bg);
        box-shadow: 0 0 15px rgba(88, 166, 255, 0.08), 0 0 30px rgba(88, 166, 255, 0.04);
    }

    @media (min-width: 600px) {
        .post-item {
            flex-direction: row;
            align-items: flex-start;
            gap: 30px;
        }
        .post-info {
            flex-grow: 1;
        }
    }

    .post-left-col {
        display: flex;
        flex-direction: column;
        gap: 15px;
        flex-shrink: 0;
    }

    .post-date {
        color: #8b949e;
        font-size: 0.95rem;
        font-family: var(--font-mono);
    }

    @media (min-width: 600px) {
        .post-left-col {
            width: 150px;
        }
    }

    .post-thumbnail {
        width: 100%;
        height: auto;
        aspect-ratio: 16 / 9;
        border-radius: 16px;
        overflow: hidden;
        display: none;
    }

    @media (min-width: 600px) {
        .post-thumbnail {
            display: block;
        }
    }

    .post-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
</style>
