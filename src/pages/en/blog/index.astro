---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogPostItem from '../../../components/BlogPostItem.astro';
import { getCollection } from 'astro:content';
import { getLangFromUrl } from '../../../i18n/utils';
import { getBlogPageText } from '../../../data/home';

const lang = getLangFromUrl(Astro.url);
const text = getBlogPageText(lang);
const blogBasePath = lang === 'zh' ? '/blog' : `/${lang}/blog`;

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title={text.title}>
    <h1 class="page-title">{text.heading}</h1>
    <p>{text.intro}</p>

    <div class="posts-list">
        {posts.map(post => (
            <BlogPostItem post={post} lang={lang} blogBasePath={blogBasePath} />
        ))}
        {posts.length === 0 && (
            <p>{text.emptyText}</p>
        )}
    </div>
</BaseLayout>

<style>
    .posts-list {
        margin-top: 40px;
        display: flex;
        flex-direction: column;
        gap: 20px;
    }
</style>
