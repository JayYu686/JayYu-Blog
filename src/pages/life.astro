---
import BaseLayout from '../layouts/BaseLayout.astro';
import LifeCardComponent from '../components/LifeCard.astro';
import { getLangFromUrl } from '../i18n/utils';
import { getLifeCategories, getLifePageText } from '../data/life';

const lang = getLangFromUrl(Astro.url);
const lifeCategories = getLifeCategories(lang);
const text = getLifePageText(lang);
---

<BaseLayout title={text.title}>
    <h1 class="page-title">{text.heading}</h1>
    <p>{text.intro}</p>

    <div class="hacks-container">
        {lifeCategories.map(section => (
            <section class="life-section">
                <h2 class="section-title">{section.category}</h2>
                <div class="cards-grid">
                    {section.items.map(item => (
                        <LifeCardComponent item={item} />
                    ))}
                </div>
            </section>
        ))}
    </div>
</BaseLayout>

<style>
    .hacks-container {
        margin-top: 40px;
    }

    .life-section {
        margin-bottom: 50px;
    }

    .section-title {
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        margin-bottom: 25px;
        font-size: 1.4rem;
    }

    .section-title::before {
        content: "## ";
        color: var(--accent-color);
    }

    .cards-grid {
        display: flex;
        flex-direction: column;
        gap: 25px;
    }
</style>
