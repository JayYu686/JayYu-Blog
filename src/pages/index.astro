---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="首页 | Jay Yu">
	<div class="hero">
		<h1>Hello, World!</h1>
		<p class="subtitle">我是 Jay Yu。一名热爱开源、构建工具并乐于分享知识的开发者。</p>
        
        <div class="terminal-wrapper">
            <div class="terminal-header">
                <span class="dot red"></span>
                <span class="dot yellow"></span>
                <span class="dot green"></span>
            </div>
            <div class="terminal-body">
                <pre><code><span class="prompt">$</span> whoami
jayyu

<span class="prompt">$</span> cat skills.txt
- 深度学习 小样本行为识别
- 软件架构设计
- 开源爱好者

<span class="prompt">$</span> status --current
持续学习，保持进步。

<span class="prompt">$</span> _<span class="cursor"></span></code></pre>
            </div>
        </div>
	</div>

    <section class="home-section">
        <h2>近期项目</h2>
        <p>欢迎前往 <a href="/projects">项目页面</a> 查看我的开源作品。</p>
    </section>

    <section class="home-section">
        <h2>最新文章</h2>
        <p>我在 <a href="/blog">博客目录</a> 记录关于开发、架构与技术的思考。</p>
    </section>
</BaseLayout>

<style>
    .hero {
        margin-top: 40px;
        margin-bottom: 60px;
    }
    
    .hero h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }
    
    .hero h1:hover {
        color: var(--accent-color);
        text-shadow: 0 0 16px var(--accent-glow), 0 0 32px rgba(88, 166, 255, 0.15);
    }
    
    .hero h1::before {
        content: "> ";
        color: var(--accent-color);
    }
    
    .subtitle {
        font-size: 1.1rem;
        color: #8b949e;
        margin-bottom: 30px;
    }

    .terminal-wrapper {
        background-color: #0d1117;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.5);
        overflow: hidden;
        margin-top: 20px;
    }

    .terminal-header {
        background-color: #161b22;
        padding: 10px 15px;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        gap: 8px;
    }

    .dot {
        width: 12px;
        height: 12px;
        border-radius: 50%;
    }

    .dot.red { background-color: #ff5f56; }
    .dot.yellow { background-color: #ffbd2e; }
    .dot.green { background-color: #27c93f; }

    .terminal-body {
        padding: 20px;
        font-size: 0.95rem;
    }

    .terminal-body pre {
        margin: 0;
        padding: 0;
        background: transparent;
        border: none;
        overflow-x: auto;
    }

    .prompt {
        color: var(--accent-color);
    }

    .cursor {
        display: inline-block;
        width: 10px;
        height: 1.2em;
        background-color: var(--text-color);
        vertical-align: bottom;
        animation: blink 1s step-end infinite;
    }

    @keyframes blink {
        0%, 100% { opacity: 1; }
        50% { opacity: 0; }
    }

    .home-section {
        margin-bottom: 40px;
    }
    
    .home-section h2 {
        transition: color 0.3s ease, text-shadow 0.3s ease;
    }
    
    .home-section h2:hover {
        color: var(--accent-color);
        text-shadow: 0 0 12px var(--accent-glow);
    }
    
    .home-section h2::before {
        content: "## ";
        color: var(--accent-color);
    }
</style>
