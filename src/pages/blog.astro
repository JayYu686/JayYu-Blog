---
import Layout from '../layouts/Layout.astro';
import TopNav from '../components/TopNav.astro';
import Sidebar from '../components/Sidebar.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="TERMINAL_EDITORIAL // 博客文章">
	<TopNav activePath="/blog/" />
	<Sidebar />
	
	<!-- Main Content -->
	<main class="pt-32 pb-24 lg:pl-64">
		<div class="max-w-4xl mx-auto px-8 lg:px-16">
			<!-- Header Section -->
			<header class="mb-20">
				<div class="flex items-center gap-3 mb-4">
					<div class="w-2 h-2 bg-primary-fixed-dim"></div>
					<span class="font-label text-xs tracking-[0.3em] uppercase text-on-surface-variant">已存档条目</span>
				</div>
				<h1 class="font-headline text-5xl md:text-7xl font-bold tracking-tighter leading-none mb-6">
					系统_日志<span class="text-primary-fixed-dim">.md</span>
				</h1>
				<p class="text-on-surface-variant font-body max-w-xl text-lg leading-relaxed">
					技术文档、架构深度解析以及关于代码与设计交叉点的哲学思考。
				</p>
			</header>
			<!-- Blog List Container -->
			<div class="space-y-16">
				<!-- Entry 01 -->
				<article class="group relative">
					<div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-12">
						<div class="md:w-32 pt-2">
							<time class="font-label text-xs tracking-widest text-on-surface-variant opacity-50 block uppercase">
								2024-10-12
							</time>
							<span class="font-label text-[10px] text-primary-fixed-dim uppercase tracking-tighter block mt-1">
								[04:22:11_UTC]
							</span>
						</div>
						<div class="flex-1">
							<h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tight mb-3 group-hover:text-primary-fixed-dim transition-colors duration-300">
								现代 Web 中色调架构的兴起
							</h2>
							<p class="text-on-surface-variant font-body leading-relaxed mb-4 max-w-2xl">
								摆脱过去十年沉重的阴影范式，转向由亮度和色调转变定义的结构。探讨去饱和色调如何创造焦点。
							</p>
							<div class="flex flex-wrap gap-3">
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#架构
								</span>
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#设计系统
								</span>
							</div>
						</div>
					</div>
				</article>
				<!-- Entry 02 -->
				<article class="group relative">
					<div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-12">
						<div class="md:w-32 pt-2">
							<time class="font-label text-xs tracking-widest text-on-surface-variant opacity-50 block uppercase">
								2024-09-28
							</time>
							<span class="font-label text-[10px] text-primary-fixed-dim uppercase tracking-tighter block mt-1">
								[11:15:00_UTC]
							</span>
						</div>
						<div class="flex-1">
							<h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tight mb-3 group-hover:text-primary-fixed-dim transition-colors duration-300">
								针对无头编辑体验优化 V8 引擎
							</h2>
							<p class="text-on-surface-variant font-body leading-relaxed mb-4 max-w-2xl">
								利用服务端检测和 JIT 分析，探索在大规模渲染高保真排版组件时的内存限制。
							</p>
							<div class="flex flex-wrap gap-3">
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#运行时
								</span>
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#性能
								</span>
							</div>
						</div>
					</div>
				</article>
				<!-- Entry 03 -->
				<article class="group relative">
					<div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-12">
						<div class="md:w-32 pt-2">
							<time class="font-label text-xs tracking-widest text-on-surface-variant opacity-50 block uppercase">
								2024-08-05
							</time>
							<span class="font-label text-[10px] text-primary-fixed-dim uppercase tracking-tighter block mt-1">
								[23:01:44_UTC]
							</span>
						</div>
						<div class="flex-1">
							<h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tight mb-3 group-hover:text-primary-fixed-dim transition-colors duration-300">
								命令行界面的心理学分析
							</h2>
							<p class="text-on-surface-variant font-body leading-relaxed mb-4 max-w-2xl">
								为什么开发者在等宽网格中感到舒适，以及受终端启发的 UI 如何回归主流消费级应用。
							</p>
							<div class="flex flex-wrap gap-3">
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#用户研究
								</span>
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#终端
								</span>
							</div>
						</div>
					</div>
				</article>
				<!-- Entry 04 -->
				<article class="group relative">
					<div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-12">
						<div class="md:w-32 pt-2">
							<time class="font-label text-xs tracking-widest text-on-surface-variant opacity-50 block uppercase">
								2024-07-19
							</time>
							<span class="font-label text-[10px] text-primary-fixed-dim uppercase tracking-tighter block mt-1">
								[02:55:09_UTC]
							</span>
						</div>
						<div class="flex-1">
							<h2 class="font-headline text-2xl md:text-3xl font-bold tracking-tight mb-3 group-hover:text-primary-fixed-dim transition-colors duration-300">
								TypeScript 5.x 中的异步模式匹配
							</h2>
							<p class="text-on-surface-variant font-body leading-relaxed mb-4 max-w-2xl">
								利用结构化类型构建更健壮的状态机。深入探讨无需 switch 语句样板代码的详尽性检查。
							</p>
							<div class="flex flex-wrap gap-3">
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#开发
								</span>
								<span class="bg-surface-container-high px-2 py-1 font-label text-[10px] uppercase tracking-wider border border-outline-variant/15 text-on-secondary-container">
									#类型系统
								</span>
							</div>
						</div>
					</div>
				</article>
			</div>
			<!-- Pagination/Footer Actions -->
			<footer class="mt-32 pt-12 border-t border-outline-variant/15">
				<div class="flex justify-between items-center">
					<button class="font-label text-xs tracking-widest uppercase text-on-surface-variant hover:text-primary-fixed-dim transition-colors flex items-center gap-2">
						<span class="material-symbols-outlined text-sm">arrow_back</span>
						上一页日志
					</button>
					<button class="font-label text-xs tracking-widest uppercase text-primary-fixed-dim flex items-center gap-2">
						下一页日志
						<span class="material-symbols-outlined text-sm">arrow_forward</span>
					</button>
				</div>
			</footer>
		</div>
	</main>
	
	<Footer />
</Layout>
