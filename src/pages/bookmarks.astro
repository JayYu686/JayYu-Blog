---
import BaseLayout from '../layouts/BaseLayout.astro';
import BookmarkSectionComponent from '../components/BookmarkSection.astro';
import { getLangFromUrl } from '../i18n/utils';
import { getBookmarks, getBookmarksPageText } from '../data/bookmarks';

const lang = getLangFromUrl(Astro.url);
const bookmarks = getBookmarks(lang);
const text = getBookmarksPageText(lang);
---

<BaseLayout title={text.title}>
    <h1 class="page-title">{text.heading}</h1>
    <p>{text.intro}<a href={text.navLinkUrl}>{text.navLinkText}</a></p>

    <div class="bookmarks-container">
        {bookmarks.map(section => (
            <BookmarkSectionComponent section={section} />
        ))}
    </div>
</BaseLayout>

<style>
    .bookmarks-container {
        margin-top: 40px;
    }
</style>
