---
import BaseLayout from '../layouts/BaseLayout.astro';

const bookmarks = [
    { category: "开发者工具", items: [
        { name: "Regex101", url: "https://regex101.com/", desc: "在线正则表达式测试与调试工具。" },
        { name: "AST Explorer", url: "https://astexplorer.net/", desc: "语法树分析与探索工具。" },
        { name: "JSON Crack", url: "https://jsoncrack.com/", desc: "直观地将 JSON 数据可视化为图表。" }
    ]},
    { category: "设计与灵感", items: [
        { name: "Awwwards", url: "https://www.awwwards.com/", desc: "全球优秀的网页设计灵感与评选。" },
        { name: "Fontshare", url: "https://www.fontshare.com/", desc: "免费高质量商用字体服务。" }
    ]},
    { category: "阅读与学习", items: [
        { name: "MDN Web Docs", url: "https://developer.mozilla.org/", desc: "Web 开发的终极指南。" },
        { name: "Hacker News", url: "https://news.ycombinator.com/", desc: "科技新闻与高质量讨论区。" }
    ]}
];
---

<BaseLayout title="收藏 | Jay Yu">
    <h1 class="page-title">bookmarks</h1>
    <p>一些我觉得非常有用的网站、工具、资源的精选，更多网站请参考我的资源导航网站：<a href="https://jayyu686.top/">JayYuの资源导航</a></p>

    <div class="bookmarks-container">
        {bookmarks.map(section => (
            <section class="bookmark-section">
                <h2>{section.category}</h2>
                <ul class="bookmark-list">
                    {section.items.map(item => (
                        <li>
                            <a href={item.url} target="_blank" rel="noopener noreferrer" class="bookmark-link">{item.name}</a>
                            <p class="bookmark-desc">{item.desc}</p>
                        </li>
                    ))}
                </ul>
            </section>
        ))}
    </div>
</BaseLayout>

<style>
    .bookmarks-container {
        margin-top: 40px;
    }

    .bookmark-section {
        margin-bottom: 40px;
    }

    .bookmark-section h2 {
        border-bottom: 1px solid var(--border-color);
        padding-bottom: 10px;
        margin-bottom: 20px;
        font-size: 1.3rem;
    }
    
    .bookmark-section h2::before {
        content: "## ";
        color: var(--accent-color);
    }

    .bookmark-list {
        list-style: none;
        padding: 0;
        margin: 0;
    }

    .bookmark-list li {
        margin-bottom: 20px;
        padding-left: 15px;
        border-left: 2px solid var(--border-color);
    }
    
    .bookmark-list li:hover {
        border-left-color: var(--accent-color);
        box-shadow: 0 0 12px rgba(88, 166, 255, 0.08);
    }

    .bookmark-link {
        font-size: 1.1rem;
        font-weight: bold;
        display: inline-block;
        margin-bottom: 5px;
    }

    .bookmark-desc {
        margin: 0;
        color: #8b949e;
        font-size: 0.95rem;
    }
</style>
