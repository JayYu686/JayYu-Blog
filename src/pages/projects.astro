---
import BaseLayout from '../layouts/BaseLayout.astro';

const projects = [
    { name: "ArxivChef", desc: "抓取对应研究方向的 arxiv 最新论文。", lang: "Python", stars: 2, url: "https://github.com/JayYu686/ArxivChef" },
    { name: "jayyu686-nav", desc: "个人资源导航网站。", lang: "Astro", stars: 3, url: "https://github.com/JayYu686/jayyu686-nav" },
    { name: "JayYu-Blog", desc: "我的个人博客网站，采用极客风格构建。", lang: "Astro", stars: 0, url: "https://github.com/JayYu686/JayYu-Blog" }
];
---

<BaseLayout title="项目 | Jay Yu">
    <h1 class="page-title">projects</h1>
    <p>以下是我在 GitHub 上维护的部分开源项目合集。</p>

    <div class="projects-grid">
        {projects.map(project => (
            <a href={project.url} target="_blank" class="project-card">
                <div class="card-header">
                    <h3>{project.name}</h3>
                </div>
                <p class="desc">{project.desc}</p>
                <div class="card-footer">
                    <span class="lang"><span class="lang-dot"></span> {project.lang}</span>
                    <span class="stars">⭐ {project.stars}</span>
                </div>
            </a>
        ))}
    </div>
</BaseLayout>

<style>
    .projects-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 20px;
        margin-top: 30px;
    }

    .project-card {
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 20px;
        background-color: var(--code-bg);
        border: 1px solid var(--border-color);
        border-radius: 6px;
        transition: all 0.2s ease;
        text-decoration: none;
        color: var(--text-color);
    }

    .project-card:hover {
        border-color: var(--accent-color);
        transform: translateY(-2px);
        text-decoration: none;
    }

    .card-header h3 {
        margin: 0 0 10px 0;
        color: var(--accent-color);
        font-size: 1.2rem;
    }

    .desc {
        font-size: 0.95rem;
        margin: 0 0 20px 0;
        flex-grow: 1;
        color: #8b949e;
    }

    .card-footer {
        display: flex;
        justify-content: flex-start;
        gap: 15px;
        font-size: 0.85rem;
        color: #8b949e;
    }

    .lang-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        background-color: #f1e05a; 
        margin-right: 4px;
        vertical-align: middle;
    }
</style>
