---
// TopNav.astro
interface Props {
	activePath?: string;
}

const { activePath = '/' } = Astro.props;

const links = [
    { name: '项目', path: '/projects/' },
    { name: '博客', path: '/blog/' },
    { name: '资源', path: '/bookmarks/' },
    { name: '生活窍门', path: '/life-hacks/' },
];
---

<nav class="fixed top-0 w-full z-50 bg-[#121317]/80 backdrop-blur-xl">
    <div class="flex justify-between items-center px-8 py-4 max-w-7xl mx-auto">
        <a href="/" class="text-xl font-black tracking-tighter text-[#00FF00] font-headline">终端_编辑部</a>
        
        <div class="hidden md:flex gap-8 items-center font-['Space_Grotesk'] tracking-tight font-bold uppercase text-sm">
            {links.map((link) => (
                <a 
                    href={link.path} 
                    class={activePath === link.path 
                        ? 'text-[#00FF00] border-b-2 border-[#00FF00] pb-1' 
                        : 'text-gray-400 hover:text-[#00FF00] transition-colors duration-200'}
                >
                    {link.name}
                </a>
            ))}
        </div>
        
        <div class="flex items-center gap-4">
            <div class="relative hidden sm:block">
                <span class="material-symbols-outlined absolute left-3 top-1/2 -translate-y-1/2 text-on-surface-variant text-sm">search</span>
                <input class="bg-surface-container-low border-none text-xs font-label py-2 pl-10 pr-4 rounded focus:ring-1 focus:ring-primary-container w-48 transition-all" placeholder="系统查询..." type="text"/>
            </div>
            <button class="md:hidden text-[#00FF00]">
                <span class="material-symbols-outlined">menu</span>
            </button>
        </div>
    </div>
</nav>

<!-- Mobile Navigation (Bottom) - Originally was separate but logically belongs to Nav -->
<nav class="md:hidden fixed bottom-0 left-0 w-full bg-[#121317]/95 backdrop-blur-xl py-3 px-6 flex justify-around items-center z-50 ghost-border-top">
    <a class="flex flex-col items-center gap-1 text-[#00FF00]" href="/projects/">
        <span class="material-symbols-outlined" data-icon="terminal">terminal</span>
        <span class="font-label text-[8px] uppercase tracking-tighter">项目</span>
    </a>
    <a class="flex flex-col items-center gap-1 text-gray-400" href="/blog/">
        <span class="material-symbols-outlined" data-icon="article">article</span>
        <span class="font-label text-[8px] uppercase tracking-tighter">博客文章</span>
    </a>
    <a class="flex flex-col items-center gap-1 text-gray-400" href="#">
        <span class="material-symbols-outlined" data-icon="settings">settings</span>
        <span class="font-label text-[8px] uppercase tracking-tighter">系统配置</span>
    </a>
</nav>
