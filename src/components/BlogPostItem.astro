---
import type { CollectionEntry } from 'astro:content';

interface Props {
    post: CollectionEntry<'blog'>;
    lang: 'zh' | 'en';
    blogBasePath: string;
}

const { post, lang, blogBasePath } = Astro.props;

const dateLocale = lang === 'zh' ? 'zh-CN' : 'en-US';
const dateOptions: Intl.DateTimeFormatOptions = lang === 'zh'
    ? { year: 'numeric', month: '2-digit', day: '2-digit' }
    : { year: 'numeric', month: 'short', day: 'numeric' };

const formattedDate = lang === 'zh'
    ? post.data.pubDate.toLocaleDateString(dateLocale, dateOptions).replace(/\//g, '-')
    : post.data.pubDate.toLocaleDateString(dateLocale, dateOptions);
---

<article class="post-item">
    <a href={`${blogBasePath}/${post.id}`} class="post-link">
        <div class="post-info">
            <time class="post-date" datetime={post.data.pubDate.toISOString()}>
                {formattedDate}
            </time>
            <h2>{post.data.title}</h2>
            <p class="post-desc">{post.data.description}</p>
        </div>
        <div class="post-thumbnail">
            <img src={post.data.heroImage || "/cover.webp"} onerror="this.onerror=null;this.src='/cover.webp';" alt="" />
        </div>
    </a>
</article>

<style>
    .post-item {
        background-color: transparent;
        border-left: 2px solid transparent;
        padding: 20px;
        transition: all 0.2s ease;
    }

    .post-item:hover {
        border-left-color: var(--accent-color);
        background-color: var(--code-bg);
        box-shadow: 0 0 15px rgba(88, 166, 255, 0.08), 0 0 30px rgba(88, 166, 255, 0.04);
    }

    .post-link {
        display: flex;
        flex-direction: column;
        gap: 20px;
        text-decoration: none;
        color: inherit;
    }

    @media (min-width: 600px) {
        .post-link {
            flex-direction: row;
            align-items: center;
            justify-content: space-between;
        }
    }

    .post-info {
        display: flex;
        flex-direction: column;
        flex-grow: 1;
        gap: 8px;
    }

    .post-date {
        color: var(--secondary-text);
        font-size: 0.9rem;
        font-family: var(--font-mono);
    }

    .post-info h2 {
        margin: 0;
        font-size: 1.3rem;
        color: var(--text-color);
        transition: color 0.2s ease;
    }

    .post-item:hover .post-info h2 {
        color: var(--accent-color);
    }

    .post-info h2::before {
        content: "";
    }

    .post-desc {
        margin: 0;
        color: var(--secondary-text);
        font-size: 0.95rem;
        line-height: 1.6;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
        text-overflow: ellipsis;
    }

    .post-thumbnail {
        width: 100%;
        max-width: 240px;
        flex-shrink: 0;
        aspect-ratio: 16 / 9;
        border-radius: 12px;
        overflow: hidden;
        display: none;
    }

    @media (min-width: 600px) {
        .post-thumbnail {
            display: block;
        }
    }

    .post-thumbnail img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .post-item:hover .post-thumbnail img {
        transform: scale(1.05);
    }
</style>
